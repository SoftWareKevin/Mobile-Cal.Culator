<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#111111"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/calculatorDisplay"
        android:layout_width="330dp"
        android:layout_height="212dp"
        android:layout_marginTop="40dp"
        android:background="#1e1e1e"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.489"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/caloriesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/digital_7"
            android:letterSpacing="0.08"
            android:text="CALORIES LEFT"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/caloriesLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/digital_7"
            android:letterSpacing="0.1"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/caloriesLabel" />

        <TextView
            android:id="@+id/proteinText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/digital_7"
            android:letterSpacing="0.05"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/carbsText" />

        <TextView
            android:id="@+id/carbsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/digital_7"
            android:letterSpacing="0.05"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/proteinText"
            app:layout_constraintEnd_toStartOf="@id/fatText" />

        <TextView
            android:id="@+id/fatText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/digital_7"
            android:letterSpacing="0.05"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/carbsText"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ListView
        android:id="@+id/listView"
        android:layout_width="371dp"
        android:layout_height="286dp"
        android:layout_marginBottom="16dp"
        android:background="#1e1e1e"
        android:choiceMode="singleChoice"
        app:layout_constraintBottom_toTopOf="@id/bottomButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/calculatorDisplay"
        app:layout_constraintVertical_bias="0.461" />

        <TextView
            android:id="@+id/foodText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="No food added yet"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="12dp"
            android:background="#1e1e1e"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="@id/listView"
            app:layout_constraintStart_toStartOf="@id/listView"
            app:layout_constraintEnd_toEndOf="@id/listView"/>

    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/settings_button"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/digital_7"
            android:backgroundTint="@android:color/darker_gray" />

        <Button
            android:id="@+id/removeBtn"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Remove"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/digital_7"
            android:backgroundTint="@android:color/darker_gray" />

        <Button
            android:id="@+id/record_button"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Records"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/digital_7"
            android:backgroundTint="@android:color/darker_gray" />

        <Button
            android:id="@+id/add_food_button"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Add Food"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/digital_7"
            android:backgroundTint="@android:color/darker_gray" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
